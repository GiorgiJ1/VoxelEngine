/// Exports the MeshData to a standard .obj file and an accompanying .mtl file.
/// It splits faces by material ID so Unity can automatically apply different colored materials.
pub fn export_obj_mtl(mesh: &MeshData, base_path: &Path) -> io::Result<()> {
    // Determine filenames based on the base path provided
    let obj_path = base_path.with_extension("obj");
    let mtl_path = base_path.with_extension("mtl");
    
    let mtl_filename = mtl_path.file_name().unwrap().to_string_lossy();

    // -------------------------------------------------------------------------
    // 1. WRITE THE .MTL FILE
    // -------------------------------------------------------------------------
    let mut mtl_file = File::create(&mtl_path)?;
    
    // Collect all unique material IDs used in this mesh
    let mut unique_ids = mesh.voxel_ids.clone();
    unique_ids.sort_unstable();
    unique_ids.dedup();

    writeln!(mtl_file, "# Material library for Voxel Engine export")?;
    for id in &unique_ids {
        // Find the first vertex that matches this material ID to capture its color
        if let Some(pos) = mesh.voxel_ids.iter().position(|x| x == id) {
            let color = mesh.positions.get(pos).map(|_| {
                // If your MeshData structure stores explicit vertex color arrays, pull from there.
                // Assuming colors are matched during vertex construction or fallback to a lookup.
                // Since your mesh construction passes color down, we can grab it from your data structures.
                // For safety across variations, let's extract the RGB components from the vertex.
                // In your architecture, if vertex colors aren't standalone arrays in MeshData,
                // we can look them up or extract them. Let's pass a material resolver or look them up.
            });
            
            // To ensure accuracy since MeshData holds flat positions/normals, let's look up 
            // the colors that correspond to the vertex offsets.
            // Let's pull the color from the triangle face vertex index:
            let idx = pos;
            // Let's use a standard default or fallback mapping if needed, 
            // but we can extract colors cleanly if we know the palette.
        }
    }

    // Let's refine this to extract the exact colors directly from the triangles safely.
    // Every quad has 4 vertices sharing a material ID. Let's build a clean mapped map:
    let mut mtl_file = File::create(&mtl_path)?;
    writeln!(mtl_file, "# Generated by Voxel Engine")?;
    
    // We can dynamically find the colors from our mesh data by checking the vertex definitions.
    // Wait, in your `MeshData` struct uploaded in your lib:
    // pub struct MeshData { pub positions: Vec<[f32; 3]>, pub normals: Vec<[f32; 3]>, pub voxel_ids: Vec<u16>, pub indices: Vec<u32> }
    // It doesn't store a separate color array directly in MeshData—the main app resolves it using `material_color`.
    // Let's write the colors using your default palette definition inside this exporter to keep things self-contained!
    let default_palette = [
        (1, [0.93, 0.93, 0.94]), // White
        (2, [0.92, 0.38, 0.38]), // Coral
        (3, [0.95, 0.80, 0.25]), // Sun
        (4, [0.35, 0.75, 0.40]), // Leaf
        (5, [0.30, 0.55, 0.90]), // Sky
        (6, [0.58, 0.38, 0.85]), // Grape
        (7, [0.28, 0.28, 0.31]), // Charcoal
        (8, [0.75, 0.42, 0.22]), // Rust
    ];

    for (id, rbg) in default_palette.iter() {
        writeln!(mtl_file, "newmtl VoxelMat_{}", id)?;
        writeln!(mtl_file, "Kd {} {} {}", rbg[0], rbg[1], rbg[2])?; // Diffuse color
        writeln!(mtl_file, "Illum 1")?;                            // Flat shading model
        writeln!(mtl_file, "Ka 0.2 0.2 0.2")?;                      // Ambient
        writeln!(mtl_file, "Ks 0.0 0.0 0.0")?;                      // No specular gloss
        writeln!(mtl_file, "")?;
    }

    // -------------------------------------------------------------------------
    // 2. WRITE THE .OBJ FILE
    // -------------------------------------------------------------------------
    let mut obj_file = File::create(&obj_path)?;

    writeln!(obj_file, "# Voxel Engine Export")?;
    writeln!(obj_file, "mtllib {}", mtl_filename)?;
    writeln!(obj_file, "")?;

    // Write all vertex positions
    for pos in &mesh.positions {
        writeln!(obj_file, "v {} {} {}", pos[0], pos[1], pos[2])?;
    }
    writeln!(obj_file, "")?;

    // Write all vertex normals
    for norm in &mesh.normals {
        writeln!(obj_file, "vn {} {} {}", norm[0], norm[1], norm[2])?;
    }
    writeln!(obj_file, "")?;

    // Write faces grouped by their respective material types (every 6 indices = 2 triangles = 1 quad)
    // Your mesher records the voxel_id per vertex. We can look up the ID associated with the face.
    let quad_count = mesh.indices.len() / 6;
    
    // Group faces by material ID to avoid spamming `usemtl` changes inside the file
    for (mat_id, _) in default_palette.iter() {
        let mut written_mat_header = false;

        for q in 0..quad_count {
            let i0 = mesh.indices[q * 6] as usize;
            // Find which material this specific quad belongs to
            let current_quad_mat = mesh.voxel_ids.get(i0).copied().unwrap_or(0);

            if current_quad_mat == *mat_id {
                if !written_mat_header {
                    writeln!(obj_file, "usemtl VoxelMat_{}", mat_id)?;
                    written_mat_header = true;
                }

                // OBJ indices are 1-based. We map vertex index and normal index directly.
                // Triangle 1
                let t1_0 = mesh.indices[q * 6] + 1;
                let t1_1 = mesh.indices[q * 6 + 1] + 1;
                let t1_2 = mesh.indices[q * 6 + 2] + 1;
                writeln!(obj_file, "f {}//{} {}//{} {}//{}", t1_0, t1_0, t1_1, t1_1, t1_2, t1_2)?;

                // Triangle 2
                let t2_0 = mesh.indices[q * 6 + 3] + 1;
                let t2_1 = mesh.indices[q * 6 + 4] + 1;
                let t2_2 = mesh.indices[q * 6 + 5] + 1;
                writeln!(obj_file, "f {}//{} {}//{} {}//{}", t2_0, t2_0, t2_1, t2_1, t2_2, t2_2)?;
            }
        }
    }

    println!("Successfully exported OBJ to: {:?}", obj_path);
    println!("Successfully exported MTL to: {:?}", mtl_path);
    Ok(())
}








fn create_depth_view(device: &wgpu::Device, config: &wgpu::SurfaceConfiguration) -> wgpu::TextureView {
    let size = wgpu::Extent3d {
        width: config.width.max(1),
        height: config.height.max(1),
        depth_or_array_layers: 1,
    };
    let desc = wgpu::TextureDescriptor {
        label: Some("depth_texture"),
        size,
        mip_level_count: 1,
        sample_count: 1,
        dimension: wgpu::TextureDimension::D2,
        format: wgpu::TextureFormat::Depth32Float,
        usage: wgpu::TextureUsages::RENDER_ATTACHMENT | wgpu::TextureUsages::TEXTURE_BINDING,
        view_formats: &[],
    };
    let texture = device.create_texture(&desc);
    texture.create_view(&wgpu::TextureViewDescriptor::default())
}



